# Required: Anthropic API key for Claude Opus 4.7
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: model override (default: claude-opus-4-7)
# Other options: claude-sonnet-4-6 (cheaper), claude-haiku-4-5 (fastest/cheapest)
# CLAUDE_MODEL=claude-opus-4-7

# Optional: max tokens for output (default: 32000, must use streaming)
# CLAUDE_MAX_TOKENS=32000

# Optional: effort level - low | medium | high | xhigh | max
# (xhigh recommended for agentic / coding tasks; max is Opus-only)
# CLAUDE_EFFORT=high
