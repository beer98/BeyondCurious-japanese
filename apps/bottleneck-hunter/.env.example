# 必填：DeepSeek API key（https://platform.deepseek.com/api_keys）
DEEPSEEK_API_KEY=sk-...

# 可选：模型
# - deepseek-chat       V3，通用 + tool calling（默认）
# - deepseek-reasoner   R1，深度推理（自审阶段用，token 更贵但更细）
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_MODEL_CRITIC=deepseek-reasoner

# 可选：tool calling 循环最大轮数（防止无限循环）
# TOOL_LOOP_MAX_ITERS=20

# 可选：当日上下文（手动触发 workflow 时填）
# PORTFOLIO="$LITE 8% / $AXTI 5% / cash 30%"
# MACRO_NOTE="MSFT 盘后财报，CPI 08:30 ET"
